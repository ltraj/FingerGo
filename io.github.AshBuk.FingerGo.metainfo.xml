<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.AshBuk.FingerGo</id>

  <name>FingerGo</name>
  <summary>Visual touch-typing trainer</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>Apache-2.0</project_license>

  <developer id="io.github.ashbuk">
    <name>Asher Buk</name>
  </developer>
  
  <description>
    <p>
      FingerGo is a cross-platform touch-typing trainer designed to improve typing
      speed and accuracy with a user-friendly and intuitive interface. It includes
      real-time keyboard visualization, a hierarchical text and code library, and
      live statistics tracking.
    </p>
    <p>Features:</p>
    <ul>
      <li>Clean Interface Design</li>
      <li>Shortcuts, Zen Mode, keyboard/Stat Toggle</li>
      <li>Real-time visual keyboard with finger mapping</li>
      <li>Hierarchical text/code library (plain text and code samples)</li>
      <li>Live stats: WPM, CPM, accuracy, per-key mistakes, session history</li>
      <li>Eye-friendly Dark/Light themes</li>
      <li>Customizable color theme</li>
      <li>Multiple keyboard layouts: QWERTY, Dvorak, JCUKEN, QWERTZ</li>
    </ul>
  </description>
  
  <launchable type="desktop-id">io.github.AshBuk.FingerGo.desktop</launchable>

